[Unit]
Description=AI Dungeon Master Server
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=tyler
Group=tyler
WorkingDirectory=/home/tyler/Desktop/aidm-main/aidm-main/ai-dungeon-master
Environment=PATH=/home/tyler/Desktop/aidm-main/aidm-main/ai-dungeon-master/.venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/tyler/Desktop/aidm-main/aidm-main/ai-dungeon-master/.venv/bin/python -m uvicorn src.server:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
